# Production environment for the FOI response system (copy to .env.production).
# Council facts default to Oxfordshire in app/config.py; override here if needed.
# docker-compose.yml force-sets the in-container LLM/DB/embedding wiring, so you
# normally only touch the values below.

# --- Public URL / HTTPS -------------------------------------------------------
# A domain pointed at this server's IP -> automatic HTTPS. Use ":80" for an
# IP-only HTTP demo. (Read by Caddy via docker-compose.)
SITE_ADDRESS=:80

# Set true once you are behind HTTPS (SITE_ADDRESS is a domain).
FOI_SESSION_COOKIE_SECURE=false

# --- Local LLM (Ollama) -------------------------------------------------------
# Model pulled by the ollama-pull service. qwen2.5:7b-instruct fits an L4 (24 GB).
# For a smaller GPU/CPU, try qwen2.5:3b-instruct or llama3.2:3b.
FOI_LLM_MODEL=qwen2.5:7b-instruct

# --- Retrieval ----------------------------------------------------------------
# Local embeddings (BGE-small, vendored in the image). Keyword is the alternative.
FOI_RETRIEVAL_PROVIDER=semantic

# --- Accounts -----------------------------------------------------------------
# Starter accounts (admin/admin etc.) are convenient for a demo but MUST be off
# for anything real — create real accounts via the admin UI first.
FOI_SEED_DEFAULT_USERS=true

# No-login demo: when true, anonymous visitors are transparently treated as
# FOI_DEMO_USERNAME so the public demo opens straight on the dashboard. This
# grants that user's role to ANYONE who can reach the URL — only use it for a
# throwaway demo on seeded data, NEVER for a real deployment. Off by default.
# FOI_DEMO_MODE=true
# FOI_DEMO_USERNAME=admin

# --- Knowledge-base ingestion (off by default; enable to crawl Oxfordshire) ---
# Turn these on to run the live crawl / WhatDoTheyKnow pull from the admin UI.
FOI_INGEST_ENABLED=false
FOI_INGEST_WEBSITE=false
FOI_INGEST_PUBLISHED_RESPONSES=false
FOI_INGEST_WHATDOTHEYKNOW=false

# --- Notifications & per-department digests (off by default; no egress) --------
# Set provider=smtp + recipients + SMTP creds to actually send.
FOI_NOTIFY_ENABLED=false
FOI_DIGEST_ENABLED=false
FOI_NOTIFY_PROVIDER=stub
FOI_NOTIFY_RECIPIENTS=
FOI_DIGEST_RECIPIENTS=
FOI_NOTIFY_FROM=foi-no-reply@oxfordshire.gov.uk
FOI_SMTP_HOST=
FOI_SMTP_PORT=587
FOI_SMTP_USERNAME=
FOI_SMTP_PASSWORD=
FOI_SMTP_USE_TLS=true
