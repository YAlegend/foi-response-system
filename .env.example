# Copy to .env and adjust. All values have safe defaults; nothing here is required to run.

# --- Core ---
FOI_ENVIRONMENT=local
FOI_DATABASE_URL=sqlite:///./foi.db

# --- Authentication / sessions ---
# Built-in username/password by default. Starter accounts are seeded on first run
# (caseworker/manager/legal/foi/admin, password = username) and MUST be changed.
# Set seed_default_users=false once you have created real accounts. Front with
# council SSO at the seam in app/auth.py.
FOI_SESSION_TTL_HOURS=12
FOI_SESSION_COOKIE_SECURE=false        # set true when served over HTTPS
FOI_SEED_DEFAULT_USERS=true

# --- Stage 3 routing ---
# Drafts below this confidence (or with missing info) are routed to a human.
FOI_AUTO_DRAFT_CONFIDENCE_THRESHOLD=0.6

# --- Retrieval (default: offline keyword ranker) ---
# "keyword" needs no extra deps. "semantic" uses a LOCAL embedding model (no data
# egress); install the optional deps (fastembed, numpy) and build the index with
# `python -m app.reindex`. Cosine scores sit lower than keyword overlap, so the
# semantic routing threshold is separate — calibrate it on your own requests.
FOI_RETRIEVAL_PROVIDER=keyword
# FOI_RETRIEVAL_PROVIDER=semantic
FOI_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
FOI_EMBEDDING_DIM=384
# Where the ONNX model is cached/loaded. Project-local by default so it can be
# vendored with the deploy artifact. Pre-fetch once online: `python -m app.fetch_model`.
FOI_EMBEDDING_CACHE_DIR=./models/fastembed
# Air-gap: forbid any model download at load (fail fast if not already vendored).
FOI_EMBEDDING_OFFLINE=false
FOI_SEMANTIC_RELEVANCE_FLOOR=0.35
# Calibrated high on purpose: cosine similarity shows topical relevance, not
# whether the specific answer exists, so only the strongest matches auto-proceed
# and the rest route to a human. Re-measure on your own knowledge base.
FOI_SEMANTIC_CONFIDENCE_THRESHOLD=0.80

# --- AI provider (default: offline stub) ---
FOI_LLM_PROVIDER=stub
# FOI_LLM_PROVIDER=anthropic
# FOI_LLM_MODEL=claude-sonnet-4-6
# FOI_LLM_API_KEY=sk-...

# --- Dedicated FOI inbox (intake source; default: offline stub mailbox) ---
# Requests arrive in a monitored mailbox, not a public form.
FOI_INBOX_PROVIDER=stub
FOI_INBOX_ADDRESS=foi@hertfordshire.gov.uk
# To connect the real mailbox, implement the connector in app/services/inbox.py
# (see the seam) and switch the provider:
# FOI_INBOX_PROVIDER=imap          # or microsoft365 / gmail

# --- Phase 0 ingestion (OFF by default — turn on to "train" on public data) ---
FOI_INGEST_ENABLED=false
FOI_INGEST_WEBSITE=false
FOI_INGEST_PUBLISHED_RESPONSES=false
# How published responses are fetched once enabled: feed (preferred) | browser
FOI_PUBLISHED_RESPONSES_FETCH_MODE=feed
FOI_INGEST_CRAWL_MAX_PAGES=200
# Crawl behaviour: seed from sitemap.xml (preferred) and skip thin/stub pages.
FOI_INGEST_USE_SITEMAP=true
FOI_INGEST_MIN_CONTENT_CHARS=400
# Local directory of exported published responses (feed mode), so the auto-refresh
# can re-ingest them unattended.
# FOI_PUBLISHED_RESPONSES_FEED_DIR=/opt/foi/published_responses

# --- Public-information auto-refresh (OFF by default; network-bound) ---
# Keeps the knowledge base current by re-running ingestion (+ reindex). No-ops
# safely unless the FOI_INGEST_* flags above are on.
# Weekly trigger: run `python -m app.refresh` from cron / a systemd timer, e.g.
#   30 6 * * 1  cd /opt/foi && . .venv/bin/activate && python -m app.refresh
FOI_KB_REFRESH_ENABLED=false
FOI_KB_REFRESH_MAX_AGE_DAYS=7           # treat KB as stale after this many days
FOI_KB_REFRESH_ON_DRAFT=false          # also refresh (if stale) before drafting a response
